# OpenClaw Phase 3A example configuration

# OpenClaw server
OPENCLAW_PORT=3300
OPENCLAW_HOST=127.0.0.1
OPENCLAW_LOG_LEVEL=info

# Telegram
OPENCLAW_TELEGRAM_BOT_TOKEN=replace-with-bot-token
# Optional shared secret for Telegram webhook requests
# OPENCLAW_TELEGRAM_SECRET_TOKEN=
# Optional: point to a mock Telegram API for local verification
# OPENCLAW_TELEGRAM_API_URL=https://api.telegram.org

# TokenWatcher backend
TOKENWATCHER_API_URL=http://127.0.0.1:3001
TOKENWATCHER_TIMEOUT_MS=60000
TOKENWATCHER_USER_AGENT=OpenClaw-TokenWatcher/phase3a

# Reuse existing authentication. Pick ONE mode.

# Option A: service account login (recommended)
TOKENWATCHER_AUTH_MODE=login
TOKENWATCHER_EMAIL=service-account@example.com
TOKENWATCHER_PASSWORD=replace-with-password

# Option B: pre-issued JWT
# TOKENWATCHER_AUTH_MODE=bearer
# TOKENWATCHER_JWT=replace-with-jwt

# Optional: pin a workspace instead of using the service account default
# TOKENWATCHER_WORKSPACE_ID=ws_12345678

# Backend ingest hardening used by production verification
# TOKENWATCH_REQUIRE_SIGNED_INGEST=true
# TOKENWATCH_INGEST_SIGNATURE_TOLERANCE_MS=300000
