# OpenClaw example configuration

# OpenClaw server
OPENCLAW_PORT=3300
OPENCLAW_HOST=127.0.0.1
OPENCLAW_LOG_LEVEL=info

# Telegram
OPENCLAW_TELEGRAM_BOT_TOKEN=replace-with-bot-token
# Optional shared secret for Telegram webhook requests
# OPENCLAW_TELEGRAM_SECRET_TOKEN=
# Optional: point to a mock Telegram API for local verification
# OPENCLAW_TELEGRAM_API_URL=https://api.telegram.org

# TokenWatcher backend
TOKENWATCHER_API_URL=http://127.0.0.1:3001
TOKENWATCHER_API_KEY=tw_oc_replace_with_openclaw_key
TOKENWATCHER_TIMEOUT_MS=60000
TOKENWATCHER_USER_AGENT=OpenClaw-TokenWatcher/1.0

# Backend ingest hardening used by production verification
# TOKENWATCH_REQUIRE_SIGNED_INGEST=true
# TOKENWATCH_INGEST_SIGNATURE_TOLERANCE_MS=300000
