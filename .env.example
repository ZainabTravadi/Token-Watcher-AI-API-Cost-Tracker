# TokenWatch example environment
# Copy to .env and edit for your environment.

# Server
NODE_ENV=development
PORT=3001

# PostgreSQL database URL (required for runtime)
# Format: postgresql://user:password@host:port/dbname
# For Neon: postgresql://user:password@host/dbname?sslmode=require
# For local development: postgresql://postgres:postgres@localhost:5432/tokenwatch
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tokenwatch

# JWT secret (required in production)
# Generate a secure random 32+ char string for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-key-please-set-in-production

# CORS origins (comma-separated)
# Required in production to allow frontend requests
# Example: CORS_ORIGIN=https://app.example.com,https://staging.example.com
#CORS_ORIGIN=http://localhost:5173

# Simulator controls
# By default simulators are enabled in development and disabled otherwise
# To explicitly enable/disable in production set ENABLE_SIMULATORS=true/false
#ENABLE_SIMULATORS=false

# Retention (optional)
# Keep telemetry data for N days, then delete
#TELEMETRY_RETENTION_DAYS=30
#TELEMETRY_RETENTION_BATCH=1000
#TELEMETRY_RETENTION_APPLY=false

# Build info (set by CI/CD)
#BUILD_TIME=
